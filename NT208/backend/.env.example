# OpenAI-compatible API
# Supports: OpenAI, AgentRita, GreenNode, or any OpenAI-compatible endpoint
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_VERIFY_SSL=true

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite+aiosqlite:///./medical_chatbot.db

# WHO ICD-11 API (đăng ký miễn phí tại icd.who.int/icdapi)
ICD_CLIENT_ID=your-icd-client-id
ICD_CLIENT_SECRET=your-icd-client-secret

# PubMed (optional - increases rate limit from 3 to 10 req/s)
PUBMED_API_KEY=

# App
APP_NAME=Medical Chatbot
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

